---
const navLinks = [
  { href: "/", label: "হোম" },
  { href: "/courses", label: "কোর্সসমূহ" },
  { href: "/faq", label: "সাধারণ জিজ্ঞাসা" },
  { href: "/about", label: "আমাদের সম্পর্কে" },
  { href: "/contact", label: "যোগাযোগ" },
  { href: "/blog", label: "ব্লগ" },
];
---

<header
  class="fixed top-0 w-full z-50 transition-all duration-300 backdrop-blur-md bg-brand-900/80 border-b border-brand-800"
  id="navbar"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a
          href="/"
          class="text-2xl font-heading font-bold bg-clip-text text-transparent bg-gradient-to-r from-brand-accent to-brand-green"
        >
          খুদে ইঞ্জিনিয়ার
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:block">
        <ul class="flex space-x-8 items-center">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-300 hover:text-white transition-colors text-[17px] font-medium relative group"
                >
                  {link.label}
                  <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-accent transition-all group-hover:w-full" />
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="#"
              class="inline-flex items-center px-6 py-2 border border-transparent text-base font-medium rounded-full shadow-sm text-white bg-brand-accent hover:bg-brand-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent transition-colors"
            >
              ভর্তি চলছে!
            </a>
          </li>
        </ul>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          id="mobile-menu-btn"
          class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-md"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              id="menu-icon-bars"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-brand-800/95 backdrop-blur-lg border-b border-brand-700"
  >
    <ul class="px-2 pt-2 pb-6 space-y-1 sm:px-3 text-center">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block px-3 py-3 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-brand-700/50 transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-4">
        <a
          href="#"
          class="inline-block px-8 py-3 w-full border border-transparent text-base font-medium rounded-full shadow-sm text-white bg-brand-accent hover:bg-brand-accent-hover transition-colors"
        >
          ভর্তি চলছে!
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Simple Navbar scroll logic
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("shadow-lg");
    } else {
      navbar?.classList.remove("shadow-lg");
    }
  });

  // Mobile Menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
