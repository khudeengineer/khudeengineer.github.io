---
import type { Mentor } from '../data/mentors';

interface Props {
  mentor: Mentor;
}

const { mentor } = Astro.props;
---

<div class="glass-card p-6 flex flex-col items-center text-center group cursor-pointer relative overflow-hidden">
  <!-- Interactive Hover Element Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-accent/0 to-brand-green/0 group-hover:from-brand-accent/10 group-hover:to-brand-green/10 transition-colors duration-500 z-0"></div>
  
  <div class="relative z-10">
    <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-brand-800 shadow-xl mb-4 group-hover:border-brand-accent transition-colors duration-300">
      <img src={mentor.image} alt={mentor.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
    </div>
    
    <h3 class="text-xl font-heading font-bold text-white mb-1 group-hover:text-brand-accent transition-colors">{mentor.name}</h3>
    <p class="text-brand-green font-medium text-sm mb-4">{mentor.expertise}</p>
    
    <p class="text-slate-400 text-sm leading-relaxed">
      {mentor.bio}
    </p>
  </div>
</div>
