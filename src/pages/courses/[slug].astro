---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MentorCard from '../../components/MentorCard.astro';
import { mentors } from '../../data/mentors';

// Static paths generation
export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map(course => ({
    params: { slug: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const { Content } = await render(course);

// Find assigned mentor
const mentor = mentors.find(m => m.id === course.data.mentor_id) || mentors[0];
---

<Layout title={course.data.title}>
  <!-- Hero Section for Course -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-brand-900 border-b border-brand-800">
     <!-- Abstract Graphic -->
     <div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-brand-accent/20 to-transparent pointer-events-none mix-blend-screen"></div>
     <div class="absolute -right-20 -top-20 w-64 h-64 bg-brand-green/30 rounded-full blur-3xl opacity-50"></div>
     
     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row gap-12 items-center">
       <div class="flex-1 text-left">
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-brand-800/80 border border-brand-700 backdrop-blur-sm mb-6 text-brand-green font-medium text-sm">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" /></svg>
            কোর্সের মেয়াদ: {course.data.duration}
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold text-white mb-6 leading-tight">
            {course.data.title}
          </h1>
          <p class="text-xl text-slate-300 max-w-2xl leading-relaxed">
            {course.data.short_description}
          </p>
       </div>
       <div class="w-full md:w-1/3">
          <div class="glass-card p-6 flex flex-col items-center justify-center text-center">
             <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-brand-accent mb-4">
               <img src={mentor.image} alt={mentor.name} class="w-full h-full object-cover" />
             </div>
             <p class="text-slate-400 text-sm mb-1">আপনার মেন্টর</p>
             <h4 class="text-lg font-heading font-bold text-white mb-4">{mentor.name}</h4>
             <a href="#enroll" class="w-full block px-6 py-3 font-semibold rounded-lg text-white bg-brand-accent hover:bg-brand-accent-hover focus:ring-4 focus:ring-brand-accent/50 transition-all duration-300">
               ফ্রি ডেমো ক্লাস বুক করুন
             </a>
          </div>
       </div>
     </div>
  </section>

  <!-- 2-Column Section: Intro & Markdown side + Module cards side -->
  <section class="py-24 relative bg-brand-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid lg:grid-cols-12 gap-16">
        
        <!-- Left Column: Intro (Markdown Text) -->
        <div class="lg:col-span-7 prose prose-invert prose-brand lg:prose-lg max-w-none text-slate-300">
           <Content />
        </div>
        
        <!-- Right Column: Course Content / Modules Sidebar -->
        <div class="lg:col-span-5">
          <div class="sticky top-28 scroll-mt-28">
            <h2 class="text-3xl font-heading font-bold text-white mb-8 pb-4 border-b border-brand-800">
              {course.data.modules ? 'কোর্স মডিউলসমূহ' : 'কোর্স হাইলাইটস'}
            </h2>
            
            {course.data.modules && course.data.modules.length > 0 ? (
              <div class="space-y-4">
                {course.data.modules.map((module, index) => (
                  <div class="glass-card p-6 flex items-start group">
                    <div class="flex-shrink-0 w-12 h-12 bg-brand-800 rounded-full flex items-center justify-center text-xl font-bold font-heading text-brand-accent border border-brand-700 group-hover:bg-brand-accent group-hover:text-white group-hover:border-brand-accent transition-colors mr-4">
                      {index + 1}
                    </div>
                    <div>
                      <h3 class="text-xl font-heading font-semibold text-white mb-2 group-hover:text-brand-accent transition-colors">{module.title}</h3>
                      <p class="text-slate-400 text-sm leading-relaxed">{module.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
               <div class="glass-card p-8 bg-brand-800/20 text-center flex flex-col items-center justify-center">
                  <div class="w-16 h-16 rounded-full bg-brand-800 flex items-center justify-center mb-6">
                     <svg class="w-8 h-8 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                  </div>
                  <h3 class="text-2xl font-bold text-white mb-4">পূর্ণাঙ্গ বোর্ড সিলেবাস</h3>
                  <p class="text-slate-400 leading-relaxed">
                     পুরো শিক্ষাবর্ষ জুড়ে ধারাবাহিকভাবে সম্পূর্ণ সিলেবাস কভার করা হবে। প্রতিটি ক্লাসের পর থাকবে এক্সক্লুসিভ নোটস এবং বোর্ড প্রশ্নের সমাধান পর্ব।
                  </p>
               </div>
            )}
            
            <div class="mt-12">
              <h3 class="text-2xl font-heading font-bold text-white mb-6 border-l-4 border-brand-green pl-3">কোর্স ইন্সট্রাক্টর</h3>
              <MentorCard mentor={mentor} />
            </div>
          </div>
        </div>
        
      </div>
      
    </div>
  </section>
  
  <style is:global>
    /* Custom Styling for Tailwind Typography (Prose) to match brand colors */
    .prose-brand {
      --tw-prose-headings: #ffffff;
      --tw-prose-links: #0ea5e9;
      --tw-prose-bold: #ffffff;
      --tw-prose-bullets: #10b981;
      --tw-prose-hr: #1e293b;
      --tw-prose-quotes: #94a3b8;
      --tw-prose-quote-borders: #0ea5e9;
      --tw-prose-th-borders: #334155;
      --tw-prose-td-borders: #1e293b;
    }
  </style>
</Layout>
