---
import Layout from '../layouts/Layout.astro';
import MentorCard from '../components/MentorCard.astro';
import { mentors } from '../data/mentors';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses');
courses.sort((a, b) => a.data.order - b.data.order);

const blogs = await getCollection('blog');
blogs.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const recentBlogs = blogs.slice(0, 3);
---

<Layout title="হোম">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden flex items-center min-h-[90vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="text-left animate-fade-in-up">
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-brand-800/80 border border-brand-700 backdrop-blur-sm mb-6">
            <span class="flex w-2 h-2 rounded-full bg-brand-green mr-2 animate-pulse"></span>
            <span class="text-sm font-medium text-slate-300">ভর্তি চলছে নতুন ব্যাচে!</span>
          </div>
          
          <h1 class="text-5xl lg:text-7xl font-heading font-extrabold text-white leading-tight mb-6">
            আগামীর <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-brand-green">ইঞ্জিনিয়ার</span> তৈরি হবে আজ থেকেই
          </h1>
          
          <p class="text-lg lg:text-xl text-slate-400 mb-8 max-w-lg leading-relaxed">
শুধু গেম খেলা নয়, প্রযুক্তি বানানোর বয়স এখনই! ৬ষ্ঠ-দ্বাদশ শ্রেণির শিক্ষার্থীদের জন্য কোডিং, রোবোটিক্স আর আইসিটির দারুণ অ্যাডভেঞ্চার। লজিক দিয়ে ভাবুক, নিজের হাতে গড়ুক আগামীর পৃথিবী।          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/courses" class="inline-flex justify-center items-center px-8 py-4 text-lg font-semibold rounded-full text-white bg-brand-accent hover:bg-brand-accent-hover focus:ring-4 focus:ring-brand-accent/50 shadow-lg shadow-brand-accent/30 transition-all duration-300">
              কোর্স এক্সপ্লোর করুন
              <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <a href="/about" class="inline-flex justify-center items-center px-8 py-4 text-lg font-semibold rounded-full text-slate-300 bg-brand-800 hover:bg-brand-700 focus:ring-4 focus:ring-brand-700/50 border border-brand-700 transition-all duration-300">
              আমাদের সম্পর্কে
            </a>
          </div>
        </div>
        
        <!-- Interactive Graphic Hero Image -->
        <div class="relative hidden lg:block h-[500px]">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-accent/20 to-brand-green/20 rounded-[2rem] transform rotate-3 scale-105 backdrop-blur-xl border border-brand-700/50 shadow-2xl"></div>
          <img src="/images/hero-bg.webp" alt="স্টুডেন্ট রোবোটিক্স" class="absolute inset-0 w-full h-full object-cover rounded-[2rem] transform -rotate-2 hover:rotate-0 transition-transform duration-700 hover:scale-105 shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Courses -->
  <section class="py-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h2 class="text-3xl lg:text-5xl font-heading font-bold text-white mb-4">আমাদের <span class="text-brand-accent">কোর্সসমূহ</span></h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg">সিলেবাসের চাপ নয়, বরং মজা করে শেখার মাধ্যমে তৈরি হবে শক্ত বেসিক।</p>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      {courses.map(course => (
        <div class="glass-card overflow-hidden border border-brand-700/50 bg-brand-800/20 w-full flex flex-col group/row">
          <!-- Course Details Block -->
          <div class="flex flex-col lg:flex-row border-b border-brand-700/50 relative">
            <a href={`/courses/${course.id}`} class="absolute inset-0 z-20"></a>
            
            <!-- Course Image -->
            <div class="lg:w-1/3 relative h-64 lg:h-auto overflow-hidden group">
               <div class="absolute inset-0 bg-gradient-to-t from-brand-900 to-transparent z-10 opacity-40"></div>
               <img src={course.data.image} alt={course.data.title} class="w-full h-full object-cover group-hover/row:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            
            <!-- Course Intro -->
            <div class="p-8 lg:w-2/3 flex flex-col justify-center relative z-30 pointer-events-none">
              <div class="flex items-center space-x-2 text-brand-green font-medium text-sm mb-3">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" /></svg>
                <span>{course.data.duration}</span>
              </div>
              <h3 class="text-3xl font-heading font-bold text-white mb-4 group-hover/row:text-brand-accent transition-colors">{course.data.title}</h3>
              <p class="text-slate-300 text-lg mb-6 leading-relaxed">{course.data.short_description}</p>
              
              <a href={`/courses/${course.id}`} class="mt-auto inline-flex items-center font-semibold text-brand-accent group-hover/row:text-white transition-colors w-fit pointer-events-auto cursor-pointer relative z-40">
                বিস্তারিত দেখুন
                <svg class="ml-2 w-5 h-5 group-hover/row:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>

          <!-- Course Modules Grid -->
          {course.data.modules && course.data.modules.length > 0 && (
            <div class="p-8 bg-brand-900/40 relative z-30">
              <h4 class="text-xl font-heading font-bold text-white mb-6 border-l-4 border-brand-accent pl-3">কোর্স মডিউলসমূহ</h4>
              <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
                {course.data.modules.map((module, index) => (
                   <div class="bg-brand-800/60 p-5 rounded-xl border border-brand-700/50 hover:border-brand-green/50 transition-colors cursor-default">
                     <div class="text-brand-accent font-bold text-sm mb-2 opacity-80">মডিউল {index + 1}</div>
                     <h5 class="text-white font-semibold mb-2">{module.title}</h5>
                     <p class="text-sm text-slate-400 line-clamp-3 leading-relaxed">{module.description}</p>
                   </div>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="py-24 relative bg-brand-900 border-t border-brand-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h2 class="text-3xl lg:text-5xl font-heading font-bold text-white mb-4">আমাদের <span class="text-brand-accent">সাম্প্রতিক আর্টিকেল</span></h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg">টেকনোলজি ও কোডিংয়ের মজাদার সব আপডেট নিয়ে আমাদের ব্লগ</p>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {recentBlogs.map(post => {
           const dateStr = new Date(post.data.publishDate).toLocaleDateString('bn-BD', { year: 'numeric', month: 'long', day: 'numeric' });
           return (
             <a href={`/blog/${post.id}`} class="glass-card group flex flex-col overflow-hidden relative border border-brand-700/50 hover:border-brand-accent transition-all duration-300 bg-brand-800/20">
               <div class="h-56 relative overflow-hidden">
                  <div class="absolute inset-0 bg-brand-900/40 group-hover:bg-brand-900/10 transition-colors z-10 duration-500"></div>
                  <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
               </div>
               <div class="p-6 flex-1 flex flex-col">
                 <div class="flex items-center space-x-2 text-brand-green font-medium text-xs mb-3 font-heading uppercase tracking-wider">
                   {post.data.tags && post.data.tags[0]}
                   <span class="mx-2 text-brand-700">•</span>
                   <span class="text-slate-500">{dateStr}</span>
                 </div>
                 <h3 class="text-2xl font-heading font-bold text-white mb-3 group-hover:text-brand-accent transition-colors leading-snug">{post.data.title}</h3>
                 <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">{post.data.excerpt}</p>
                 <div class="flex items-center mt-auto border-t border-brand-800/50 pt-4">
                    <span class="text-brand-accent font-medium hover:text-white transition-colors inline-flex items-center">
                      পড়তে থাকুন <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </span>
                 </div>
               </div>
             </a>
           )
        })}
      </div>
      <div class="text-center mt-12">
         <a href="/blog" class="inline-flex justify-center items-center px-8 py-3 text-lg font-semibold rounded-full text-slate-300 bg-brand-800 hover:bg-brand-700 focus:ring-4 focus:ring-brand-700/50 border border-brand-700 transition-all duration-300">
            সকল আর্টিকেল পড়ুন
         </a>
      </div>
    </div>
  </section>

  <!-- Our Mentors Section -->
  <section class="py-24 bg-brand-900/50 border-y border-brand-800 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h2 class="text-3xl lg:text-5xl font-heading font-bold text-white mb-4">আমাদের <span class="text-brand-green">মেন্টররা</span></h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg">যাদের হাত ধরে তৈরি হবে আগামীর প্রযুক্তি বিশ্ব।</p>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {mentors.slice(0,3).map(mentor => (
          <MentorCard mentor={mentor} />
        ))}
      </div>
      <div class="text-center mt-12">
         <a href="/about" class="text-brand-accent font-medium hover:underline inline-flex items-center">
            সকল মেন্টরদের সম্পর্কে জানুন <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
         </a>
      </div>
    </div>
  </section>

</Layout>
