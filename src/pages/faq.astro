---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: "খুদে ইঞ্জিনিয়ার একাডেমি কী?",
    answer: "খুদে ইঞ্জিনিয়ার একাডেমি হলো ৬ষ্ঠ থেকে দ্বাদশ শ্রেণির শিক্ষার্থীদের জন্য একটি বিশেষায়িত লার্নিং প্ল্যাটফর্ম, যেখানে আমরা হাতে-কলমে রোবোটিক্স, প্রোগ্রামিং এবং ইলেকট্রনিক্স শেখাই।"
  },
  {
    question: "কোর্সে ভর্তির জন্য কী কী প্রয়োজন?",
    answer: "আমাদের কোর্সে ভর্তির জন্য শুধুমাত্র শেখার প্রবল ইচ্ছা থাকলেই হবে! তবে প্র্যাক্টিসের জন্য একটি বেসিক ল্যাপটপ বা কম্পিউটার থাকলে সবচেয়ে ভালো হয়।"
  },
  {
    question: "কোর্সগুলো কি অনলাইনে হয়?",
    answer: "হ্যাঁ, আমাদের সব ক্লাস বর্তমানে অনলাইনের মাধ্যমে সরাসরি (Live) নেওয়া হয়, যাতে দেশের যেকোনো প্রান্ত থেকে শিক্ষার্থীরা যুক্ত হতে পারে।"
  },
  {
    question: "মেন্টরদের থেকে কীভাবে সাহায্য পাওয়া যাবে?",
    answer: "আমাদের প্রতিটি কোর্সের জন্য আলাদা সাপোর্ট গ্রুপ থাকে। এছাড়া ক্লাসের বাইরেও যেকোনো সমস্যায় মেন্টরদের সাথে সরাসরি যোগাযোগ করার সুযোগ রয়েছে।"
  },
  {
    question: "কোর্স শেষে কি সার্টিফিকেট দেওয়া হয়?",
    answer: "অবশ্যই! প্রতিটি কোর্স এবং প্রজেক্ট সফলভাবে সম্পন্ন করার পর শিক্ষার্থীদের ডিজিটাল সার্টিফিকেট প্রদান করা হয়।"
  }
];
---

<Layout title="সাধারণ জিজ্ঞাসা">
  <!-- Header Banner -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-brand-900 border-b border-brand-800">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-accent/50 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-heading font-extrabold text-white mb-6">
        সাধারণ <span class="text-brand-accent">জিজ্ঞাসা</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        আমাদের কোর্স এবং প্ল্যাটফর্ম সম্পর্কে আপনার মনে থাকা সাধারণ প্রশ্নগুলোর উত্তর এখানে পাবেন।
      </p>
    </div>
  </section>

  <!-- FAQ Accordion Section -->
  <section class="py-24 relative bg-brand-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <div class="glass-card faq-item overflow-hidden" data-index={index}>
            <button class="w-full p-6 text-left flex justify-between items-center group focus:outline-none">
              <span class="text-lg md:text-xl font-heading font-semibold text-white group-hover:text-brand-accent transition-colors duration-300">
                {faq.question}
              </span>
              <svg class="w-6 h-6 text-slate-500 group-hover:text-brand-accent transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-6">
              <p class="text-slate-400 leading-relaxed pt-2 border-t border-brand-700/50">
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 glass-card p-8 md:p-12 text-center border-brand-green/20">
        <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">আরও কিছু জানতে চান?</h3>
        <p class="text-slate-400 mb-8 max-w-lg mx-auto">আমাদের মেন্টরদের সাথে সরাসরি কথা বলতে অথবা যেকোনো প্রয়োজনে আজই যোগাযোগ করুন।</p>
        <a href="/contact" class="inline-flex justify-center items-center px-10 py-4 text-lg font-semibold rounded-full text-white bg-brand-accent hover:bg-brand-accent-hover shadow-lg shadow-brand-accent/20 transition-all duration-300 w-fit mx-auto whitespace-nowrap">
          যোগাযোগ করুন
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const faqItems = document.querySelectorAll('.faq-item');
  
  faqItems.forEach(item => {
    const button = item.querySelector('button');
    const answer = item.querySelector('.faq-answer');
    const svg = item.querySelector('svg');
    
    button?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      
      // Close all other items
      document.querySelectorAll('.faq-answer').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.faq-item svg').forEach(el => el.classList.remove('rotate-180'));
      
      if (!isOpen) {
        answer?.classList.remove('hidden');
        svg?.classList.add('rotate-180');
      }
    });
  });
</script>

<style>
  .faq-item svg.rotate-180 {
    transform: rotate(180deg);
  }
</style>
